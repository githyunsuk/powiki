<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.powiki.domain.mechanic.mapper.TypeMapper">

    <insert id="insertType">
        INSERT INTO type
        (
             id
            ,name
            ,generation
            ,sprite
        )
        VALUES
        (
             #{id}
            ,#{name}
            ,#{generation}
            ,#{sprite}
        )
    </insert>

    <insert id="insertTypeEfficacy">
        INSERT INTO type_efficacy
        (
             damage_type_id
            ,target_type_id
            ,damage_factor
        )
        VALUES
        (
             #{damageTypeId}
            ,#{targetTypeId}
            ,#{damageFactor}
        )
    </insert>

    <select id="retrieveAllType" resultType="com.example.powiki.domain.mechanic.model.response.TypeSummaryResponse">
        SELECT
             id
            ,name
            ,sprite
            ,color
            ,generation
        FROM type
        WHERE is_active = 'Y';
    </select>


</mapper>