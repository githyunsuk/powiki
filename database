DROP TABLE pokemon;
CREATE TABLE pokemon (
	id INT AUTO_INCREMENT PRIMARY KEY,
	pokemon_species_id INT NOT NULL,
	sort_order INT NOT NULL,
	name VARCHAR(30) NOT NULL,
	main_artwork_url VARCHAR(400),
	main_sprite_url VARCHAR(400),
	cries VARCHAR(400),
	height INT,
	weight INT,
	hp INT NOT NULL,
	attack INT NOT NULL,
	defense INT NOT NULL,
	special_attack INT NOT NULL,
	special_defense INT NOT NULL,
	speed INT NOT NULL,
	is_default CHAR(1) NOT NULL,
	is_active CHAR(1) DEFAULT 'Y' NOT NULL,
	created_at DATETIME DEFAULT CURRENT_TIMESTAMP NOT NULL,
	updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

DROP TABLE version;
CREATE TABLE version(
	id INT AUTO_INCREMENT PRIMARY KEY,
	name VARCHAR(30) NOT NULL,
	generation INT NOT NULL,
	region VARCHAR(30) NOT NULL,
	is_active CHAR(1) DEFAULT 'Y' NOT NULL,
	created_at DATETIME DEFAULT CURRENT_TIMESTAMP NOT NULL,
	updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

DROP TABLE pokemon_species;
CREATE TABLE pokemon_species (
	id INT AUTO_INCREMENT PRIMARY KEY,
	pokemon_species_name VARCHAR(30) NOT NULL,
	sort_order INT NOT NULL,
	gender_rate INT,
	is_baby CHAR(1) NOT NULL,
	is_legendary CHAR(1) NOT NULL,
	is_mythical CHAR(1) NOT NULL,
	category VARCHAR(30) NOT NULL,
	generation INT NOT NULL,
	is_active CHAR(1) DEFAULT 'Y' NOT NULL,
	created_at DATETIME DEFAULT CURRENT_TIMESTAMP NOT NULL,
	updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

DROP TABLE ability;
CREATE TABLE ability (
	id INT AUTO_INCREMENT PRIMARY KEY,
	name VARCHAR(30) NOT NULL,
	description VARCHAR(300) NOT NULL,
	is_main_series CHAR(1) NOT NULL,
	generation INT NOT NULL,
	is_active CHAR(1) DEFAULT 'Y' NOT NULL,
	created_at DATETIME DEFAULT CURRENT_TIMESTAMP NOT NULL,
	updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

DROP TABLE pokemon_ability_map;
CREATE TABLE pokemon_ability_map (
	id INT AUTO_INCREMENT PRIMARY KEY,
	pokemon_id INT NOT NULL,
	ability_id INT NOT NULL,
	pokemon_name VARCHAR(30) NOT NULL,
	ability_name VARCHAR(30) NOT NULL,
