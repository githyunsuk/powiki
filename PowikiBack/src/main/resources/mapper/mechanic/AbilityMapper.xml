<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.powiki.domain.mechanic.mapper.AbilityMapper">

    <insert id="ingestAbility">
        INSERT INTO ability
        (
             id
            ,name
            ,description
            ,generation
            ,is_main_series
        )
        VALUES
        (
             #{id}
            ,#{name}
            ,#{description}
            ,#{generation}
            ,#{isMainSeries}
        )
    </insert>

</mapper>

